{
  "name": "k1c",
  "version": "0.0.0",
  "description": "Apply a subset of Kubernetes manifests to Cloudflare",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "k1c": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli/main.ts"
  },
  "dependencies": {
    "cloudflare": "^4.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
