{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)"
  ],
  "schedule": ["before 5am on monday"],
  "timezone": "Asia/Tokyo",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    },
    {
      "matchPackageNames": ["@kubernetes/client-node", "cloudflare", "zod"],
      "groupName": "core libraries"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "Dockerfile base images"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    }
  ],
  "lockFileMaintenance": { "enabled": true, "schedule": ["before 5am on monday"] },
  "vulnerabilityAlerts": { "labels": ["security"] }
}
